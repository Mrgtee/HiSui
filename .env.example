# Google Gemini API Key for Intent Parsing
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# Google OAuth Client ID for zkLogin (e.g. 12345-abc.apps.googleusercontent.com)
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here

# Sui Network RPC URL (e.g., https://fullnode.testnet.sui.io:443)
VITE_SUI_RPC_URL=https://fullnode.testnet.sui.io:443

# Shinami API Key for zkLogin Prover (optional - falls back to Mysten Labs if omitted)
VITE_SHINAMI_API_KEY=

# HiSui On-Chain Convenience Fee Treasury Address
VITE_TREASURY_ADDRESS=your_treasury_address_here


